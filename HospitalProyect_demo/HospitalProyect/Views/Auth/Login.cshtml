@{
    Layout = null;
    ViewData["Title"] = "Login";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DPWA_Practica1</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bg-light d-flex align-items-center" style="min-height: 100vh;">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-5">
                <div class="card shadow-sm border-0 rounded-lg mt-5">
                    <div class="card-body p-5">
                        <h2 class="text-center font-weight-light mb-4">Iniciar Sesión</h2>
                        <hr />

                        <form asp-action="Login" method="post">

                            @if (ViewBag.Error != null)
                            {
                                <div class="alert alert-danger" role="alert">
                                    @ViewBag.Error
                                </div>
                            }

                            <div class="form-group mb-3">
                                <label for="email" class="control-label mb-1">Correo Electrónico</label>
                                <input type="email" id="email" name="email" class="form-control py-2" placeholder="ejemplo@correo.com" required />
                            </div>

                            <div class="form-group mb-4">
                                <label for="password" class="control-label mb-1">Contraseña</label>
                                <input type="password" id="password" name="password" class="form-control py-2" placeholder="Tu contraseña" required />
                            </div>

                            <div class="form-group mt-4 mb-0">
                                <button type="submit" class="btn btn-primary w-100 py-2">Entrar</button>
                            </div>

                            <div class="mt-4 text-center">
                                <p class="mb-0">¿No tienes cuenta? <a asp-action="Register">Regístrate aquí</a></p>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>