@model HospitalProyect.Models.UserModel

@{
    Layout = null;
    ViewData["Title"] = "Register";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DPWA_Practica1</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bg-light d-flex align-items-center" style="min-height: 100vh;">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-5">
                <div class="card shadow-sm border-0 rounded-lg mt-5">
                    <div class="card-body p-5">
                        <h2 class="text-center font-weight-light mb-2">Registrarse</h2>
                        <p class="text-center text-muted mb-4">Crea una nueva cuenta</p>
                        <hr />

                        <form asp-action="Register" method="post">
                            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                            @if (ViewBag.Error != null)
                            {
                                <div class="alert alert-danger" role="alert">
                                    @ViewBag.Error
                                </div>
                            }

                            <div class="form-group mb-3">
                                <label asp-for="Name" class="control-label mb-1">Nombre</label>
                                <input asp-for="Name" class="form-control py-2" placeholder="Ingresa tu nombre" />
                                <span asp-validation-for="Name" class="text-danger"></span>
                            </div>

                            <div class="form-group mb-3">
                                <label asp-for="Email" class="control-label mb-1">Correo Electrónico</label>
                                <input asp-for="Email" class="form-control py-2" placeholder="ejemplo@correo.com" />
                                <span asp-validation-for="Email" class="text-danger"></span>
                            </div>

                            <div class="form-group mb-4">
                                <label asp-for="Password" class="control-label mb-1">Contraseña</label>
                                <input asp-for="Password" type="password" class="form-control py-2" placeholder="Crea una contraseña" />
                                <span asp-validation-for="Password" class="text-danger"></span>
                            </div>

                            <div class="form-group mt-4 mb-0">
                                <button type="submit" class="btn btn-primary w-100 py-2">Registrarse</button>
                            </div>

                            <div class="mt-4 text-center">
                                <p class="mb-0">¿Ya tienes cuenta? <a asp-action="Login">Inicia sesión aquí</a></p>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>